    {
      "parameters": {
        "jsCode": "const raw = $('5 · Prepare Draft Data').first().json.draft_content;\nlet d;\ntry {\n  d = JSON.parse(raw);\n} catch (e) {\n  d = { post_text: raw };\n}\n\nconst parts = [d.hook, d.post_text, d.cta].filter(Boolean);\nlet text = parts.join('\\n\\n');\n\nif (Array.isArray(d.hashtags) && d.hashtags.length) {\n  text += '\\n\\n' + d.hashtags.join(' ');\n}\n\n// Image now lives as an Airtable attachment; grab its URL from the upload response\nlet imageUrl = '';\ntry {\n  const uploaded = $('11b · Upload Image to Airtable').first().json;\n  const attachments = uploaded.fields && uploaded.fields.Image;\n  if (Array.isArray(attachments) && attachments.length) {\n    imageUrl = attachments[0].url || '';\n  }\n} catch (e) {}\n\nconst filename = $('11a · Image to Base64').first().json.filename;\nconst notes = $('11a · Image to Base64').first().json.notes;\n\nreturn [{\n  json: {\n    final_text: text,\n    image_url: imageUrl || filename,\n    designer_notes: notes,\n    topic: $('5 · Prepare Draft Data').first().json.topic\n  }\n}];"
      },
