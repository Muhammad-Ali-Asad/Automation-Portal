    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst binary = item.binary && item.binary.Image;\n\nif (!binary) {\n  throw new Error('No uploaded image found on the form submission (expected binary property \"Image\").');\n}\n\nconst buffer = await this.helpers.getBinaryDataBuffer(0, 'Image');\n\nreturn [{\n  json: {\n    file_base64: buffer.toString('base64'),\n    content_type: binary.mimeType || 'image/png',\n    filename: binary.fileName || 'post-image.png',\n    notes: String(item.json['Notes for reviewer'] || '').trim()\n  }\n}];"
      },
