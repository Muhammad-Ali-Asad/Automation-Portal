    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const response = $input.item.json;\nconst results = response.organic || [];\n\nconst top = results.slice(0, 5);\n\nlet formatted = top.map((r, i) => {\n  return `${i + 1}. ${r.title}\\nSource: ${r.link}\\nSummary: ${r.snippet || 'No summary available'}`;\n}).join('\\n\\n');\n\nif (!formatted) {\n  formatted = 'No research results were found for this topic.';\n}\n\nreturn {\n  json: {\n    research_text: formatted,\n    sources: top.map(r => r.link)\n  }\n};"
      },
      "id": "c3c0e8db-cc84-487e-b5de-9f32610c6e16",
      "name": "3 · Format Research Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        944
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"llama-3.3-70b-versatile\",\n  temperature: 0.7,\n  response_format: { type: \"json_object\" },\n  messages: [\n    {\n      role: \"system\",\n      content: [\n        \"You are a content writer for Mezz (Soft Pyramid). Write ONLY for LinkedIn.\",\n        \"Use the provided research to ground the post in real, current information — reference specific facts, data points, or trends from the research where relevant.\",\n        \"\",\n        \"Return a JSON object with exactly these keys:\",\n        \"- hook (string): attention-grabbing opening line\",\n        \"- post_text (string): main body, plain text only, no markdown, no hashtags inside post_text\",\n        \"- cta (string): call to action aligned with cta_type; use empty string if cta_type is none\",\n        \"- hashtags (array): 5-8 relevant LinkedIn hashtags, each starting with #; return [] if include_hashtags is false\",\n        \"\",\n        \"Rules:\",\n        \"- Respect tone: professional | conversational | inspirational | educational\",\n        \"- Respect post_length: short (~100 words) | medium (~200 words) | long (~350 words)\",\n        \"- Naturally weave in keywords_list when provided\",\n        \"- Write for target_audience when provided\",\n        \"- Follow additional_notes when provided\",\n        \"- Avoid generic hashtags like #business, #success, #motivation\",\n        \"- Respond with valid JSON only.\"\n      ].join(\"\\n\")\n    },\n    {\n      role: \"user\",\n      content: [\n        \"Write a LinkedIn post with these inputs:\",\n        \"\",\n        \"Topic: \" + ($('1 · Request (Webhook)').item.json.body.topic || \"\"),\n        \"Tone: \" + ($('1 · Request (Webhook)').item.json.body.tone || \"professional\"),\n        \"Post length: \" + ($('1 · Request (Webhook)').item.json.body.post_length || \"medium\"),\n        \"Target audience: \" + ($('1 · Request (Webhook)').item.json.body.target_audience || \"general business audience\"),\n        \"Keywords to include: \" + (\n          ($('1 · Request (Webhook)').item.json.body.keywords_list || []).join(\", \") ||\n          ($('1 · Request (Webhook)').item.json.body.keywords || \"none specified\")\n        ),\n        \"Call to action type: \" + ($('1 · Request (Webhook)').item.json.body.cta_type || \"comment\"),\n        \"Include hashtags: \" + ($('1 · Request (Webhook)').item.json.body.include_hashtags !== false ? \"yes\" : \"no\"),\n        \"Additional instructions: \" + ($('1 · Request (Webhook)').item.json.body.additional_notes || \"none\"),\n        \"\",\n        \"CTA guidance by type:\",\n        \"- comment: ask a thoughtful question to drive comments\",\n        \"- share: encourage readers to share with their network\",\n        \"- connect: invite relevant people to connect/message\",\n        \"- visit_link: prompt readers to visit/learn more (no URL required unless provided in notes)\",\n        \"- none: keep cta as empty string\",\n        \"\",\n        \"Here is recent research from US-based sources to inform the post:\",\n        ($json.research_text || \"No research text available.\")\n      ].join(\"\\n\")\n    }\n  ]\n}) }}",
        "options": {}
      },
